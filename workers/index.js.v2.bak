/**
 * Bible Chat API Worker - 后端服务
 */
const MODEL = 'google/gemini-2.0-flash-001';

const CORS = {
  'Access-Control-Allow-Origin': '*',
  'Access-Control-Allow-Methods': 'GET,POST,PUT,OPTIONS',
  'Access-Control-Allow-Headers': 'Content-Type,Authorization,X-Api-Key',
  'Access-Control-Max-Age': '86400'
};

const SYSTEM = `你是"圣经小助手"，温和睿智的AI圣经导师。
- 精通新旧约66卷，熟悉和合本（CUV）
- 可解释经文含义、历史背景、神学教导和实际应用
- 回答时引用经文标注书卷章节
- 以圣经为核心引导用户回到神的话语`;

const DAILY_VERSES = [
  { text: "神爱世人，甚至将他的独生子赐给他们，叫一切信他的，不至灭亡，反得永生。", ref: "约翰福音 3:16", theme: "神的爱" },
  { text: "耶和华是我的牧者，我必不至缺乏。他使我躺卧在青草地上，领我在可安歇的水边。", ref: "诗篇 23:1-2", theme: "神的供应" },
  { text: "你要专心仰赖耶和华，不可倚靠自己的聪明，在你一切所行的事上都要认定他，他必指引你的路。", ref: "箴言 3:5-6", theme: "信靠神" },
  { text: "凡劳苦担重担的人可以到我这里来，我就使你们得安息。", ref: "马太福音 11:28", theme: "安息" },
  { text: "我靠着那加给我力量的，凡事都能做。", ref: "腓立比书 4:13", theme: "力量" },
  { text: "你们要先求他的国和他的义，这些东西都要加给你们了。", ref: "马太福音 6:33", theme: "优先次序" },
  { text: "不要为明天忧虑，因为明天自有明天的忧虑；一天的难处一天当就够了。", ref: "马太福音 6:34", theme: "不要忧虑" },
  { text: "我们晓得万事都互相效力，叫爱神的人得益处，就是按他旨意被召的人。", ref: "罗马书 8:28", theme: "神的旨意" },
  { text: "我留下平安给你们；我将我的平安赐给你们。我所赐的，不像世人所赐的。你们心里不要忧愁，也不要胆怯。", ref: "约翰福音 14:27", theme: "平安" },
  { text: "你们是世上的光。城造在山上是不能隐藏的。", ref: "马太福音 5:14", theme: "见证" },
  { text: "因为罪的工价乃是死；惟有神的恩赐，在我们的主基督耶稣里，乃是永生。", ref: "罗马书 6:23", theme: "救恩" },
  { text: "你们祈求，就给你们；寻找，就寻见；叩门，就给你们开门。", ref: "马太福音 7:7", theme: "祷告" },
  { text: "但那等候耶和华的必从新得力。他们必如鹰展翅上腾；他们奔跑却不困倦，行走却不疲乏。", ref: "以赛亚书 40:31", theme: "等候神" },
  { text: "如今常存的有信，有望，有爱这三样，其中最大的是爱。", ref: "哥林多前书 13:13", theme: "爱" },
  { text: "耶稣说：我就是道路、真理、生命；若不藉着我，没有人能到父那里去。", ref: "约翰福音 14:6", theme: "道路" },
  { text: "我的恩典够你用的，因为我的能力是在人的软弱上显得完全。", ref: "哥林多后书 12:9", theme: "恩典" },
  { text: "你们亲近神，神就必亲近你们。", ref: "雅各书 4:8", theme: "亲近神" },
  { text: "出于神的话，没有一句不带能力的。", ref: "路加福音 1:37", theme: "神的话" },
  { text: "凡接待他的，就是信他名的人，他就赐他们权柄作神的儿女。", ref: "约翰福音 1:12", theme: "儿女" },
  { text: "你要保守你心，胜过保守一切，因为一生的果效是由心发出。", ref: "箴言 4:23", theme: "保守己心" },
  { text: "不可叫人小看你年轻，总要在言语、行为、爱心、信心、清洁上，都作信徒的榜样。", ref: "提摩太前书 4:12", theme: "榜样" },
  { text: "耶和华说：我知道我向你们所怀的意念是赐平安的意念，不是降灾祸的意念，要叫你们末后有指望。", ref: "耶利米书 29:11", theme: "盼望" },
  { text: "所以，你们要去，使万民作我的门徒，奉父、子、圣灵的名给他们施洗。", ref: "马太福音 28:19", theme: "大使命" },
  { text: "你们若常常遵守我的道，就真是我的门徒；你们必晓得真理，真理必叫你们得以自由。", ref: "约翰福音 8:31-32", theme: "真理" },
  { text: "看哪，我站在门外叩门，若有听见我声音就开门的，我要进到他那里去，我与他，他与我一同坐席。", ref: "启示录 3:20", theme: "邀请" },
  { text: "不要效法这个世界，只要心意更新而变化，叫你们察验何为神的善良、纯全、可喜悦的旨意。", ref: "罗马书 12:2", theme: "更新" },
  { text: "主就是那灵；主的灵在哪里，那里就得以自由。", ref: "哥林多后书 3:17", theme: "自由" },
  { text: "我实实在在地告诉你们，那听我话、又信差我来者的，就有永生；不至于定罪，是已经出死入生了。", ref: "约翰福音 5:24", theme: "永生" },
  { text: "愿赐平安的神亲自使你们全然成圣！又愿你们的灵与魂与身子得蒙保守，在我们主耶稣基督降临的时候，完全无可指摘！", ref: "帖撒罗尼迦前书 5:23", theme: "成圣" },
  { text: "圣灵所结的果子，就是仁爱、喜乐、和平、忍耐、恩慈、良善、信实、温柔、节制。", ref: "加拉太书 5:22-23", theme: "圣灵的果子" }
];

async function getAuthUser(request, env) {
  const token = request.headers.get('Authorization')?.replace('Bearer ', '');
  if (!token) return null;
  const username = await env.USER_KV.get(`token:${token}`);
  if (!username) return null;
  const userData = await env.USER_KV.get(`user:${username}`);
  return userData ? JSON.parse(userData) : null;
}

async function handleChat(request, env) {
  const { messages, apiKey } = await request.json();
  const key = apiKey || env.OPENROUTER_KEY;
  if (!key) return json({ error: 'API key needed', needSetup: true }, 401);

  const res = await fetch('https://openrouter.ai/api/v1/chat/completions', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${key}`, 'HTTP-Referer': 'https://biblechat.cc', 'X-Title': 'Bible Chat' },
    body: JSON.stringify({ model: MODEL, messages: [{ role: 'system', content: SYSTEM }, ...(messages || []).slice(-20)], max_tokens: 2048, temperature: 0.7 })
  });
  const data = await res.json();
  if (!res.ok) return json({ error: data.error?.message || 'AI error' }, res.status);
  return json({ content: data.choices?.[0]?.message?.content || '' });
}

async function handleRegister(request, env) {
  const { username, password, email } = await request.json();
  if (!username || !password || username.length < 2 || password.length < 4) return json({ error: '用户名至少2字符，密码至少4字符' }, 400);
  if (await env.USER_KV.get(`user:${username}`)) return json({ error: '用户名已存在' }, 409);
  const user = { username, password, email: email || '', createdAt: Date.now(), bibleProgress: {}, bookmarks: [], notes: [], favorites: [] };
  await env.USER_KV.put(`user:${username}`, JSON.stringify(user));
  const token = btoa(`${username}:${Date.now()}`);
  await env.USER_KV.put(`token:${token}`, username, { expirationTtl: 86400 * 30 });
  return json({ success: true, token, user: { username, email: user.email, createdAt: user.createdAt } });
}

async function handleLogin(request, env) {
  const { username, password } = await request.json();
  const userData = await env.USER_KV.get(`user:${username}`);
  if (!userData) return json({ error: '用户不存在' }, 404);
  const user = JSON.parse(userData);
  if (user.password !== password) return json({ error: '密码错误' }, 401);
  const token = btoa(`${username}:${Date.now()}`);
  await env.USER_KV.put(`token:${token}`, username, { expirationTtl: 86400 * 30 });
  return json({ success: true, token, user: { username, email: user.email, createdAt: user.createdAt, bibleProgress: user.bibleProgress || {}, bookmarks: user.bookmarks || [], notes: user.notes || [], favorites: user.favorites || [] } });
}

async function handleProfile(request, env) {
  const user = await getAuthUser(request, env);
  if (!user) return json({ error: '未登录' }, 401);
  if (request.method === 'PUT') {
    const updates = await request.json();
    if (updates.bibleProgress) user.bibleProgress = updates.bibleProgress;
    if (updates.bookmarks) user.bookmarks = updates.bookmarks;
    if (updates.notes) user.notes = updates.notes;
    if (updates.favorites) user.favorites = updates.favorites;
    await env.USER_KV.put(`user:${user.username}`, JSON.stringify(user));
  }
  return json({ username: user.username, email: user.email || '', createdAt: user.createdAt, bibleProgress: user.bibleProgress || {}, bookmarks: user.bookmarks || [], notes: user.notes || [], favorites: user.favorites || [] });
}

async function handleDailyVerse(request, env) {
  const url = new URL(request.url);
  const date = url.searchParams.get('date') || new Date().toISOString().slice(0, 10);
  const cached = await env.USER_KV.get(`verse:${date}`);
  if (cached) return new Response(cached, { headers: { 'Content-Type': 'application/json', 'Access-Control-Allow-Origin': '*' } });
  const idx = Math.abs(date.split('-').reduce((a, b) => a + parseInt(b), 0)) % DAILY_VERSES.length;
  const result = { ...DAILY_VERSES[idx], date, bgTheme: (idx % 6) + 1 };
  await env.USER_KV.put(`verse:${date}`, JSON.stringify(result));
  return json(result);
}

async function handleWechatJSSDK(request, env) {
  const url = new URL(request.url);
  const pageUrl = url.searchParams.get('url') || '';
  if (!env.WECHAT_APPID) return json({ configured: false });
  let token = await env.USER_KV.get('wechat:token');
  if (!token) {
    const tr = await fetch(`https://api.weixin.qq.com/cgi-bin/token?grant_type=client_credential&appid=${env.WECHAT_APPID}&secret=${env.WECHAT_SECRET}`);
    const td = await tr.json();
    token = td.access_token;
    if (token) await env.USER_KV.put('wechat:token', token, { expirationTtl: 7000 });
  }
  if (!token) return json({ error: '微信token获取失败' }, 500);
  const tr2 = await fetch(`https://api.weixin.qq.com/cgi-bin/ticket/getticket?access_token=${token}&type=jsapi`);
  const td2 = await tr2.json();
  const ticket = td2.ticket;
  if (!ticket) return json({ error: 'ticket获取失败' }, 500);
  const noncestr = Math.random().toString(36).substring(2, 18);
  const timestamp = Math.floor(Date.now() / 1000);
  const hash = await crypto.subtle.digest('SHA-1', new TextEncoder().encode(`jsapi_ticket=${ticket}&noncestr=${noncestr}&timestamp=${timestamp}&url=${pageUrl}`));
  const signature = Array.from(new Uint8Array(hash)).map(b => b.toString(16).padStart(2, '0')).join('');
  return json({ appId: env.WECHAT_APPID, timestamp, nonceStr: noncestr, signature });
}

async function handlePodcast(request, env) {
  const { passage, style, apiKey } = await request.json();
  const key = apiKey || env.OPENROUTER_KEY;
  if (!key) return json({ error: 'API key needed' }, 401);
  const prompt = style === 'podcast'
    ? `请以播客主播风格，用温暖亲切的中文讲解这段经文（5-8分钟音频时长）。包含：开场问候、背景介绍、逐节解读、生活应用、结束祷告。经文：${passage}`
    : `请深入浅出讲解这段经文：1.历史背景 2.经文含义 3.神学要点 4.生活应用。经文：${passage}`;
  const res = await fetch('https://openrouter.ai/api/v1/chat/completions', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${key}`, 'HTTP-Referer': 'https://biblechat.cc' },
    body: JSON.stringify({ model: MODEL, messages: [{ role: 'user', content: prompt }], max_tokens: 2048, temperature: 0.8 })
  });
  const data = await res.json();
  const content = data.choices?.[0]?.message?.content || '';
  const segments = content.split(/(?<=[。！？\n])/).filter(s => s.trim()).map((s, i) => ({ index: i, text: s.trim(), duration: Math.max(5, Math.ceil(s.length * 0.3)) }));
  return json({ content, segments });
}

function json(data, status = 200) {
  return new Response(JSON.stringify(data), { status, headers: { 'Content-Type': 'application/json', 'Access-Control-Allow-Origin': '*' } });
}

export default {
  async fetch(request, env) {
    const url = new URL(request.url);
    if (request.method === 'OPTIONS') return new Response(null, { headers: CORS });

    try {
      const p = url.pathname;
      if (p === '/api/chat') return await handleChat(request, env);
      if (p === '/api/auth/register') return await handleRegister(request, env);
      if (p === '/api/auth/login') return await handleLogin(request, env);
      if (p === '/api/user/profile') return await handleProfile(request, env);
      if (p === '/api/verse/daily') return await handleDailyVerse(request, env);
      if (p === '/api/wechat/jssdk') return await handleWechatJSSDK(request, env);
      if (p === '/api/podcast') return await handlePodcast(request, env);
      if (p === '/api/health') return json({ status: 'ok', time: Date.now() });
      return json({ error: 'Not Found' }, 404);
    } catch (err) {
      return json({ error: err.message }, 500);
    }
  }
};
